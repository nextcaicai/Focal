{
  "name": "focal-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "description": "Local-first RSS reader with BYOK AI",
  "author": "Focal",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/nextcaicai/Focal",
  "repository": {
    "url": "https://github.com/nextcaicai/Focal",
    "type": "git"
  },
  "scripts": {
    "build:packages": "pnpm --filter \"./packages/**\" --if-present run build",
    "build:web": "pnpm --dir apps/desktop run build:web",
    "dedupe:locales": "eslint --fix locales/**",
    "depcheck": "npx depcheck --quiet",
    "dev:web": "turbo run @follow/web#dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons:sync-mobile": "tsx scripts/sync-mobile-icons.ts",
    "icons:update": "tsx scripts/update-icon.ts && pnpm run icons:sync-mobile",
    "lint": "pnpm run lint:tsl && eslint",
    "lint:fix": "eslint --fix",
    "lint:tsl": "tsslint --project apps/desktop/layer/*/tsconfig.json",
    "mitproxy": "bash scripts/run-proxy.sh",
    "polyfill-optimize": "pnpx nolyfill install",
    "postinstall": "pnpm run build:packages",
    "prepare": "simple-git-hooks && corepack prepare",
    "reinstall": "rm -rf node_modules && rm -rf apps/**/node_modules && rm -rf packages/**/node_modules && pnpm install",
    "test": "cross-env CI=1 pnpm --recursive run test",
    "typecheck": "pnpm --recursive --if-present run typecheck"
  },
  "devDependencies": {
    "@babel/generator": "7.29.1",
    "@babel/parser": "7.29.0",
    "@babel/traverse": "7.29.0",
    "@babel/types": "7.29.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@eslint/compat": "1.4.1",
    "@iconify-json/lucide": "1.2.112",
    "@lobehub/icons-static-svg": "1.91.0",
    "@tsslint/cli": "2.0.7",
    "@tsslint/config": "2.0.7",
    "@tsslint/eslint": "2.0.7",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/node": "5.6.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.1",
    "eslint-config-hyoban": "4.0.10",
    "fast-glob": "3.3.3",
    "glob": "11.0.3",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "raw-body": "3.0.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "6.1.2",
    "serialize-error": "2.1.0",
    "simple-git-hooks": "2.13.1",
    "svg-parser": "2.0.4",
    "tar": "7.5.7",
    "tsx": "4.21.0",
    "turbo": "2.8.7",
    "typescript": "catalog:",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "eslint --fix",
      "prettier --ignore-unknown --write"
    ],
    "locales/**/*.json": [
      "npm run dedupe:locales",
      "git add locales"
    ]
  }
}
